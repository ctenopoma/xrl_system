# XRL System 環境変数設定ファイル
# このファイルを .env にコピーして使用してください
# cp .env.example .env

# -------------------------------------------------------
# LLM バックエンド設定
# -------------------------------------------------------

# litellm のモデル名
# - llama.cpp サーバー (OpenAI互換): openai/<任意の名前>
# - OpenAI:   gpt-4o
# - Anthropic: claude-3-5-sonnet-20241022
# - Ollama:   ollama/llama3
XRL_MODEL_NAME=openai/Qwen3.5-9B

# APIエンドポイントのベースURL
# llama.cpp サーバー: http://<host>:<port>/v1
# OpenAI の場合は空欄でOK
XRL_API_BASE=http://localhost:8088/v1

# APIキー
# llama.cpp / Ollama などローカルサーバーは "dummy" でOK
# OpenAI の場合は実際のキーを設定
XRL_API_KEY=dummy

# -------------------------------------------------------
# 生成パラメータ (省略時はサーバー側設定を使用)
# -------------------------------------------------------

# 最大生成トークン数
XRL_MAX_TOKENS=2048

# Temperature (省略するとサーバー側の --temp に従う)
# XRL_TEMPERATURE=0.7

# -------------------------------------------------------
# 埋め込みモデル設定 (SySLLM コンセンサス選択で使用)
# -------------------------------------------------------

# 埋め込みモデル名 (litellm 形式)
# - OpenAI: text-embedding-3-small / text-embedding-3-large
# - ローカルサーバーが埋め込みAPIを提供する場合: openai/<モデル名>
# - 省略時: text-embedding-3-small
XRL_EMBED_MODEL_NAME=text-embedding-3-small

# 埋め込み専用エンドポイントURL
# - ローカルLLM + OpenAI埋め込みを組み合わせる場合に設定
# - 省略時は XRL_API_BASE を流用
# XRL_EMBED_API_BASE=https://api.openai.com/v1
